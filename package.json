{
  "name": "@orchestra-mcp/icons",
  "version": "0.2.0",
  "description": "React SVG icon components for Orchestra MCP",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./code": { "import": "./dist/code/index.js", "types": "./dist/code/index.d.ts" },
    "./launcher": { "import": "./dist/launcher/index.js", "types": "./dist/launcher/index.d.ts" },
    "./boxicons": { "import": "./dist/boxicons/index.js", "types": "./dist/boxicons/index.d.ts" }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/orchestra-mcp/icons"
  },
  "funding": "https://github.com/sponsors/fadymondy",
  "license": "MIT",
  "dependencies": {
        "@resvg/resvg-js": "^2.6.2",
    "boxicons": "^2.1.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["orchestra", "mcp", "react", "components", "icons"]
}
